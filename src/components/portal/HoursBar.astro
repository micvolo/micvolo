---
import type { Project, WorkLog } from '@/lib/db';

interface Props {
  project: Project;
  workLogs: WorkLog[];
}

const { project, workLogs } = Astro.props;

const totalWorked = workLogs.reduce((sum, l) => sum + l.hours, 0);

const expectedHours =
  project.hours_mode === 'fixed' && project.hourly_rate && project.quote_amount
    ? project.quote_amount / project.hourly_rate
    : null;

const pct = expectedHours
  ? Math.min((totalWorked / expectedHours) * 100, 100)
  : 0;

const isOver = expectedHours ? totalWorked > expectedHours : false;

const CATS = [
  { key: 'design',      label: 'Design' },
  { key: 'dev',         label: 'Dev' },
  { key: 'call',        label: 'Calls' },
  { key: 'fix',         label: 'Fixes' },
  { key: 'content',     label: 'Content' },
  { key: 'maintenance', label: 'Maint.' },
] as const;

const byCategory = CATS.map(c => ({
  ...c,
  hours: workLogs
    .filter(l => l.category === c.key)
    .reduce((s, l) => s + l.hours, 0),
})).filter(c => c.hours > 0);

function fmt(h: number) {
  return Number.isInteger(h) ? `${h}h` : `${h.toFixed(1)}h`;
}

const effectiveRate =
  project.hours_mode === 'fixed' && project.quote_amount && totalWorked > 0
    ? project.quote_amount / totalWorked
    : null;

function fmtRate(r: number) {
  return `€${r % 1 === 0 ? r : r.toFixed(2)}/h`;
}
---

<section class="portal-section hours-section">
  <div class="section-title">Hours</div>

  <div class="hours-top">
    <div class="hours-count">
      <span class="hours-worked">{fmt(totalWorked)}</span>
      {expectedHours && (
        <>
          <span class="hours-sep">/</span>
          <span class="hours-expected">{fmt(expectedHours)} est.</span>
        </>
      )}
    </div>
    {expectedHours && (
      <span class="hours-pct" class:list={[{ 'is-over': isOver }]}>
        {isOver ? `+${fmt(totalWorked - expectedHours)} over` : `${Math.round(pct)}%`}
      </span>
    )}
  </div>

  {expectedHours && (
    <div class:list={['hours-track', { 'is-over': isOver }]}>
      <div class="hours-fill" style={`width: ${pct}%`}></div>
    </div>
  )}

  {byCategory.length > 0 && (
    <ul class="hours-cats">
      {byCategory.map(c => (
        <li class="hours-cat">
          <span class="cat-label">{c.label}</span>
          <span class="cat-hours">{fmt(c.hours)}</span>
        </li>
      ))}
    </ul>
  )}

  {effectiveRate && (
    <div class="hours-rate">
      <span class="rate-label">Effective rate</span>
      <span class:list={['rate-value', { 'is-under': effectiveRate < (project.hourly_rate ?? 0) }]}>
        {fmtRate(effectiveRate)}
      </span>
      {project.hourly_rate && effectiveRate !== project.hourly_rate && (
        <span class="rate-agreed">quoted {fmtRate(project.hourly_rate)}</span>
      )}
    </div>
  )}
</section>
