---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const list = await getCollection("projects");
list.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/projects/*.{webp,png,jpg,jpeg,avif}",
    { eager: true }
);
const getImage = (path: string) => {
    const filename = path.split("/").pop();
    return images[`/src/assets/projects/${filename}`]?.default;
};
---

<div class="page">
    <div class="pageHeading">
        <div>(M)</div>
        <div>(V)</div>
        <div>{new Date().getFullYear()}</div>
    </div>
    <div class="pageTitle">SELECTED WORKS</div>
    <div class="content">
        {
            list.map((p) => (
                <a href={p.data.url} target="_blank" class="card">
                    <div class="heading">
                        <div class="tags">{p.data.tags}</div>
                        <span>{p.data.title}</span>
                        <span>{p.data.date.getFullYear()}</span>
                    </div>
                    <Image
                        src={getImage(p.data.image)}
                        alt={p.data.title}
                        width={1920}
                        height={1080}
                        format="webp"
                        quality={85}
                    />
                </a>
            ))
        }
    </div>
</div>
<style lang="scss">
    .content {
        display: flex;
        flex-direction: column;
        gap: var(--padding2);
        padding: var(--padding2);
        @media (max-width: 64rem) {
            padding: var(--padding2) var(--padding);
        }
        .card {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 1rem;
            > .heading {
                display: flex;
                flex-wrap: wrap;
                justify-content: space-between;
                font-size: clamp(1.8rem, 6vw, 2.5rem);
                padding-top: 2rem;
                font-variation-settings:
                    "wdth" 92,
                    "wght" 600,
                    "opsz" 20;
                .tags {
                    flex-basis: 100%;
                    font-size: clamp(0.6rem, 6vw, 0.8rem);
                    text-transform: uppercase;
                    opacity: 0.8;
                    padding-left: 0.1rem;
                }
            }

            .text {
                font-size: clamp(0.8rem, 3vw, 1rem);
            }
        }
    }
</style>
