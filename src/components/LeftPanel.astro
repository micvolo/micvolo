---
import Menu from "./Menu.astro";
import { getEntry } from "astro:content";

const { page } = Astro.props;
const settings = await getEntry("settings", "settings");
---

<div
    class="panel left"
    class:list={{ open: page === "index" }}
    transition:persist
>
    <div>
        <a href="/">
            <h1>{settings.data.title}</h1>
        </a>
        <h2 class="subhero" set:html={settings.data.hero} />
    </div>
    <h3 class="subhero right" set:html={settings.data.description} />
    <script>
        document.addEventListener("click", (e) => {
            const el = (e.target as HTMLElement).closest("[data-copy]") as HTMLElement | null;
            if (!el) return;

            const text = el.dataset.copy || "";
            navigator.clipboard.writeText(text);

            const chip = document.createElement("div");
            chip.textContent = "COPIED";
            chip.className = "copy-chip";
            const r = el.getBoundingClientRect();
            chip.style.left = r.left + r.width / 2 + "px";
            chip.style.top = r.top + "px";
            document.body.appendChild(chip);
            requestAnimationFrame(() => chip.classList.add("show"));
            setTimeout(() => chip.classList.add("hide"), 600);
            setTimeout(() => chip.remove(), 900);
        });
    </script>
<div class="menu-wrapper">
        <Menu />
    </div>
</div>

<style lang="scss">
    .panel {
        justify-content: space-between;
        align-items: flex-start;
        padding: var(--padding);
        min-height: 0;
        transition: min-height 0.8s;
        &.open {
            min-height: 100vh;
            min-height: 100svh;
        }

        h1 {
            font-size: clamp(1rem, 8vw, 2rem);
        }
        .subhero {
            padding: 1rem 0;
            font-size: 1rem;
            font-weight: bold;
            text-transform: uppercase;
            pointer-events: none;
            white-space: pre-line;
            :global(a) {
                pointer-events: all;
                font-variation-settings: "wdth" 92, "wght" 600, "slnt" -12;
            }
            :global(i) {
                font-style: normal;
                font-variation-settings:
                    "wdth" 92,
                    "wght" 600,
                    "slnt" -12;
            }
            :global(small) {
                font-size: 0.7rem;
                opacity: 0.9;
                text-transform: none;
                pointer-events: none;
                :global([data-copy]) {
                    pointer-events: all;
                    cursor: copy;
                }
            }
            &.right {
                align-self: flex-end;
            }
        }
    }
</style>
