---
import { getEntry } from "astro:content";
import { marked } from "marked";

const settings = await getEntry("settings", "settings");
---

<div class="contacts" set:html={marked.parse(settings.data.contacts)} />

<style lang="scss">
    .contacts {
        align-self: flex-end;
        display: flex;
        gap: 1rem;
        :global(p) {
            display: contents;
        }
        :global(a) {
            font-size: 0.75rem;
            text-decoration: underline;
        }
    }
</style>
